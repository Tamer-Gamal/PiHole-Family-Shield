# ============================================================================
#  Pi-hole setup configuration  -  copy this file to  setup.conf  and edit it
# ============================================================================
#  This is the ONLY file you need to change to build a new Pi-hole.
#  Lines starting with #  are comments (ignored).  Keep the  KEY="value"  shape.
#
#     cp setup.conf.example setup.conf
#     nano setup.conf        # edit the values below, then save (Ctrl+O, Enter, Ctrl+X)
#
#  Then run:   sudo ./bootstrap.sh
# ----------------------------------------------------------------------------

# The name this Pi will answer to on your network (letters/numbers/dashes).
# You will reach the admin page at  http://<this-name>.local/admin
PIHOLE_HOSTNAME="pihole"

# The password for the Pi-hole admin web page. CHANGE THIS.
# Pick something you will remember - you type it to log into the dashboard.
PIHOLE_ADMIN_PASSWORD="change-me-please"

# Where Pi-hole sends questions it is allowed to answer (your "upstream" DNS).
# Defaults below are Cloudflare (fast + privacy-friendly).
#   Google:      8.8.8.8 / 8.8.4.4
#   Quad9:       9.9.9.9 / 149.112.112.112   (adds its own malware blocking)
#   Cloudflare:  1.1.1.1 / 1.0.0.1           (default)
# If you turn on Unbound below, these are IGNORED (Unbound becomes the upstream).
UPSTREAM_DNS_1="1.1.1.1"
UPSTREAM_DNS_2="1.0.0.1"

# Set to "true" to also install Unbound - a private recursive resolver that
# removes the need to trust ANY upstream company with your browsing. Recommended
# for privacy, but adds a couple of minutes to setup. "false" keeps it simple.
INSTALL_UNBOUND="false"

# Add the curated ad + malware/phishing blocklists in  ../config/blocklists.txt
# on top of Pi-hole's default list. "true" recommended.
ADD_CURATED_BLOCKLISTS="true"

# ---------------------------------------------------------------------------
# FAMILY / KID PROTECTION  (this kit's main purpose)
# ---------------------------------------------------------------------------
# "true" turns on the child-safety layer:
#   - forces SafeSearch on Google, Bing & DuckDuckGo (no adult results)
#   - forces YouTube "Restricted Mode"
#   - blocks known adult / pornographic websites for the whole network
# Honest limit: DNS filtering blocks bad *sites* and forces safe search, but it
# cannot see inside an allowed site and is not a 100% guarantee - use it WITH
# device parental controls (Screen Time / Family Link) and conversations.
FAMILY_MODE="true"

# Also block gambling / betting sites. "true" recommended for a family network.
FAMILY_BLOCK_GAMBLING="true"

# YouTube restriction strength: "strict" (recommended for young kids) or "moderate".
YOUTUBE_MODE="strict"

# Block VPN / DoH / proxy tools that a tech-savvy kid could use to ESCAPE the
# filter. Powerful, but it can also block a legitimate VPN you use for work.
# Leave "false" unless you understand that trade-off. If "true", also set your
# router to send ALL devices' DNS only to this Pi.
BLOCK_DNS_BYPASS="false"

# OPTIONAL: your country's Google domain, so SafeSearch is forced there too.
# Example for Saudi Arabia:  FAMILY_GOOGLE_CCTLD="google.com.sa"
# Leave empty if your family only uses google.com.
FAMILY_GOOGLE_CCTLD=""

# Your timezone (controls log timestamps). Full list:
#   timedatectl list-timezones
TIMEZONE="Asia/Riyadh"

# ---------------------------------------------------------------------------
# ADVANCED (most people leave these alone)
# ---------------------------------------------------------------------------

# Leave empty to keep whatever IP the Pi currently has (recommended - then make
# a DHCP RESERVATION for it in your router so it never changes). Only set this
# if you know how to assign a static IP and understand your subnet, e.g.
#   STATIC_IP="192.168.1.10/24"
#   STATIC_GATEWAY="192.168.1.1"
STATIC_IP=""
STATIC_GATEWAY=""
